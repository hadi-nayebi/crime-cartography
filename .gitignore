# Node / Remotion
node_modules/
surface/remotion/node_modules/
.remotion/
out/
*.log

# Rendered video outputs (large; published via Releases/YouTube, not committed)
videos/**/out/
*.mp4
*.mov
*.webm
!videos/**/*sample*.mp4

# Thumbnail CANDIDATES are regenerable frames extracted from the mp4 (studio
# publish flow). The chosen one is copied to videos/<slug>/thumbnail.jpg, which
# IS committed as part of the per-video publish record.
videos/**/thumbs/

# Raw source pulls are reproducible via pipeline/sources/*.mjs — keep them out of
# git (can be large), but DO keep the provenance sidecar that records each fetch.
data/**/raw/*
!data/**/raw/_fetch_meta.json

# OS / editor
.DS_Store
*.swp
.env
.env.local

# Private agent harnesses and local codebase maps. These may be published later
# as separate, intentionally reviewed artifacts; they are not production output.
.claude/
.codex/
.understand-anything/
/AGENTS.md
/CLAUDE.md

# Private operational state. Files remain available to the local studio and
# routines, but raw feedback, internal deliberation, telemetry, and account
# snapshots are not public production artifacts.
experiment/briefings/
experiment/channel/
experiment/BATCH2-SCOUT.md
experiment/CRITIC-LENS.md
experiment/CRITIC.md
experiment/DECISIONS.md
experiment/FLEET.md
experiment/HARNESS.md
experiment/REFLECTIONS.md
experiment/WATCHER-LENS.md
experiment/studio-feedback.json
videos/*/feedback.json
pipeline/routine-runs.mjs
/tmp/
.hn/
# Local dashboard screenshots are verification artifacts, not public product output.
public/dashboard-vps-email.png
# OAuth secrets for the publish pipeline — NEVER commit
.secrets/

# Fleet coordination lockfiles — transient, never committed
experiment/.driver.lock
experiment/.notes.lock
experiment/.critic.lock
