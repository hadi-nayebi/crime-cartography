# Node / Remotion
node_modules/
surface/remotion/node_modules/
.remotion/
out/
*.log

# Rendered video outputs (large; published via Releases/YouTube, not committed)
videos/**/out/
*.mp4
*.mov
*.webm
!videos/**/*sample*.mp4

# Thumbnail CANDIDATES are regenerable frames extracted from the mp4 (studio
# publish flow). The chosen one is copied to videos/<slug>/thumbnail.jpg, which
# IS committed as part of the per-video publish record.
videos/**/thumbs/

# Raw source pulls are reproducible via pipeline/sources/*.mjs — keep them out of
# git (can be large), but DO keep the provenance sidecar that records each fetch.
data/**/raw/*
!data/**/raw/_fetch_meta.json

# OS / editor
.DS_Store
*.swp
.env
.env.local

# Claude tooling: keep the skills + hooks (they document the workflow), but the
# job memory is transient working state — not a published artifact.
.claude/.tmp/
.claude/memory/
/tmp/
.hn/
# OAuth secrets for the publish pipeline — NEVER commit
.secrets/
